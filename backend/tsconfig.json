{
    "compilerOptions": {
        "strict": true,
        "target": "ES2020",
        "module": "node16",
        "moduleResolution": "node16",
        "types": ["node", "express"],
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "./src"
    },
    "include": ["src"],
    "exclude": ["node_modules", "**/*.spec.ts", "**/*.test.ts"]
}